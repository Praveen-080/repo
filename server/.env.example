# Server Environment Variables
PORT=5000

# Firebase Admin SDK
# Preferred: set GOOGLE_APPLICATION_CREDENTIALS to an absolute path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
# Optional alternatives:
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=fish-market-becb6

# Firestore database (named database seen in Firebase Console)
FIRESTORE_DATABASE_ID=shakthifishmarket

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
